generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
  role  String

  reservas Reserva[]
  sessions Session[]
}

model Universidade {
  id       Int       @id @default(autoincrement())
  nome     String
  cidade   String
  locais   Local[]
  horarios Horario[]
}

model Local {
  id             Int            @id @default(autoincrement())
  nome           String
  universidadeId Int
  universidade   Universidade   @relation(fields: [universidadeId], references: [id])
  horarios       HorarioLocal[]
}

model Horario {
  id             Int            @id @default(autoincrement())
  hora           String
  tipo           String
  universidadeId Int
  universidade   Universidade   @relation(fields: [universidadeId], references: [id])
  locais         HorarioLocal[]
  reservas       Reserva[]
}

model HorarioLocal {
  id        Int @id @default(autoincrement())
  horarioId Int
  localId   Int

  horario Horario @relation(fields: [horarioId], references: [id])
  local   Local   @relation(fields: [localId], references: [id])
}

model Reserva {
  id        Int @id @default(autoincrement())
  userId    Int
  horarioId Int
  localId   Int

  user    User    @relation(fields: [userId], references: [id])
  horario Horario @relation(fields: [horarioId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
