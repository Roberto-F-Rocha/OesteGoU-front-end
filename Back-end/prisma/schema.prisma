generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  student
  driver
}

enum UserStatus {
  active
  pending
  inactive
  blocked
}

enum AgreementStatus {
  pending
  active
  rejected
  inactive
  canceled
}

enum TripType {
  ida
  volta
}

enum ReservationStatus {
  confirmed
  canceled
  absent
}

enum DocumentType {
  profile_photo
  enrollment_proof
  driver_license
  general
}

enum DocumentStatus {
  pending
  approved
  rejected
}

enum ModerationStatus {
  not_required
  pending
  approved
  rejected
}

enum AuditAction {
  login
  logout
  create
  update
  delete
  view
  approve
  reject
  cancel
  access
  error
}

enum NotificationType {
  info
  success
  warning
  error
}

enum MaintenanceTicketSeverity {
  low
  medium
  high
}

enum MaintenanceTicketStatus {
  open
  in_progress
  resolved
  canceled
}

model City {
  id        Int      @id @default(autoincrement())
  name      String
  state     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  universities       University[]
  pickupPoints       PickupPoint[]
  vehicles           Vehicle[]
  routes             TransportRoute[]
  requesterLinks     CityAgreement[] @relation("RequesterCity")
  partnerLinks       CityAgreement[] @relation("PartnerCity")
  auditLogs          AuditLog[]
  pushSendLogs       PushSendLog[]
  maintenanceTickets MaintenanceTicket[]

  @@unique([name, state])
  @@index([state])
}

model CityAgreement {
  id              Int             @id @default(autoincrement())
  requesterCityId Int
  partnerCityId   Int
  status          AgreementStatus @default(pending)
  title           String?
  description     String?
  startsAt        DateTime?
  endsAt          DateTime?
  requestedById   Int?
  approvedById    Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  requesterCity City  @relation("RequesterCity", fields: [requesterCityId], references: [id])
  partnerCity   City  @relation("PartnerCity", fields: [partnerCityId], references: [id])
  requestedBy   User? @relation("AgreementRequestedBy", fields: [requestedById], references: [id])
  approvedBy    User? @relation("AgreementApprovedBy", fields: [approvedById], references: [id])

  @@unique([requesterCityId, partnerCityId])
  @@index([status])
}

model User {
  id           Int        @id @default(autoincrement())
  nome         String
  email        String     @unique
  senha        String
  role         UserRole
  status       UserStatus @default(active)
  cpf          String?    @unique
  phone        String?
  birthDate    DateTime?
  institution  String?
  photo        String?
  cep          String?
  street       String?
  number       String?
  neighborhood String?
  cityId       Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  city                   City?               @relation(fields: [cityId], references: [id])
  documents              UserDocument[]
  reservations           Reservation[]
  sessions               Session[]
  auditLogs              AuditLog[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  analyticsEvents        AnalyticsEvent[]
  pushSendLogs           PushSendLog[]       @relation("PushSentBy")
  requestedAgreements    CityAgreement[]     @relation("AgreementRequestedBy")
  approvedAgreements     CityAgreement[]     @relation("AgreementApprovedBy")
  drivenRoutes           TransportRoute[]    @relation("RouteDriver")
  reviewedDocuments      UserDocument[]      @relation("DocumentReviewedBy")
  maintenanceTickets     MaintenanceTicket[] @relation("TicketOpenedBy")
  resolvedTickets        MaintenanceTicket[] @relation("TicketResolvedBy")

  @@index([role])
  @@index([cityId])
  @@index([status])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType @default(info)
  readAt    DateTime?
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PushSendLog {
  id             Int      @id @default(autoincrement())
  title          String
  message        String
  url            String?
  target         String
  targetRole     UserRole?
  cityId         Int?
  sentById       Int?
  recipients     Int      @default(0)
  createdAt      DateTime @default(now())

  city   City? @relation(fields: [cityId], references: [id])
  sentBy User? @relation("PushSentBy", fields: [sentById], references: [id])

  @@index([cityId])
  @@index([target])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  userId    Int?
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

model UserDocument {
  id               Int              @id @default(autoincrement())
  userId           Int
  type             DocumentType
  status           DocumentStatus   @default(pending)
  fileName         String
  filePath         String?
  fileData         Bytes?
  mimeType         String
  sizeBytes        Int
  moderationStatus ModerationStatus @default(not_required)
  moderationReason String?
  reviewedById     Int?
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user       User  @relation(fields: [userId], references: [id])
  reviewedBy User? @relation("DocumentReviewedBy", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
}

model University {
  id        Int      @id @default(autoincrement())
  name      String
  cityName  String?
  cityId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city         City?         @relation(fields: [cityId], references: [id])
  schedules    Schedule[]
  pickupPoints PickupPoint[]

  @@index([cityId])
}

model PickupPoint {
  id           Int      @id @default(autoincrement())
  name         String
  address      String?
  latitude     Float?
  longitude    Float?
  type         TripType @default(ida)
  cityId       Int
  universityId Int?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  city         City          @relation(fields: [cityId], references: [id])
  university   University?   @relation(fields: [universityId], references: [id])
  routePoints  RoutePoint[]
  reservations Reservation[]

  @@index([cityId])
  @@index([type])
  @@index([universityId])
}

model Vehicle {
  id          Int      @id @default(autoincrement())
  plate       String   @unique
  name        String?
  model       String?
  capacity    Int
  active      Boolean  @default(true)
  cityId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city               City                @relation(fields: [cityId], references: [id])
  routes             TransportRoute[]
  maintenanceTickets MaintenanceTicket[]

  @@index([cityId])
}

model Schedule {
  id           Int      @id @default(autoincrement())
  time         String
  type         TripType
  active       Boolean  @default(true)
  universityId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university   University?      @relation(fields: [universityId], references: [id])
  routes       TransportRoute[]
  reservations Reservation[]

  @@index([type])
  @@index([universityId])
}

model TransportRoute {
  id          Int      @id @default(autoincrement())
  name        String
  cityId      Int
  scheduleId  Int
  vehicleId   Int?
  driverId    Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city         City          @relation(fields: [cityId], references: [id])
  schedule     Schedule      @relation(fields: [scheduleId], references: [id])
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  driver       User?         @relation("RouteDriver", fields: [driverId], references: [id])
  points       RoutePoint[]
  reservations Reservation[]

  @@index([cityId])
  @@index([scheduleId])
  @@index([driverId])
}

model RoutePoint {
  id            Int @id @default(autoincrement())
  routeId       Int
  pickupPointId Int
  order         Int @default(0)

  route       TransportRoute @relation(fields: [routeId], references: [id])
  pickupPoint PickupPoint    @relation(fields: [pickupPointId], references: [id])

  @@unique([routeId, pickupPointId])
  @@index([pickupPointId])
}

model Reservation {
  id            Int               @id @default(autoincrement())
  userId        Int
  scheduleId    Int
  routeId       Int?
  pickupPointId Int?
  dayOfWeek     String?
  status        ReservationStatus @default(confirmed)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user        User            @relation(fields: [userId], references: [id])
  schedule    Schedule        @relation(fields: [scheduleId], references: [id])
  route       TransportRoute? @relation(fields: [routeId], references: [id])
  pickupPoint PickupPoint?    @relation(fields: [pickupPointId], references: [id])

  @@index([userId])
  @@index([scheduleId])
  @@index([routeId])
  @@index([status])
  @@index([dayOfWeek])
}

model MaintenanceTicket {
  id           Int                       @id @default(autoincrement())
  vehicleId    Int
  cityId       Int
  openedById   Int
  title        String
  description  String
  severity     MaintenanceTicketSeverity @default(medium)
  status       MaintenanceTicketStatus   @default(open)
  resolution   String?
  resolvedById Int?
  resolvedAt   DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id])
  city       City    @relation(fields: [cityId], references: [id])
  openedBy   User    @relation("TicketOpenedBy", fields: [openedById], references: [id])
  resolvedBy User?   @relation("TicketResolvedBy", fields: [resolvedById], references: [id])

  @@index([vehicleId])
  @@index([cityId])
  @@index([openedById])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@index([vehicleId, status])
  @@index([cityId, status, createdAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int?
  cityId      Int?
  action      AuditAction
  entity      String?
  entityId    String?
  description String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  path        String?
  method      String?
  statusCode  Int?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])
  city City? @relation(fields: [cityId], references: [id])

  @@index([userId])
  @@index([cityId])
  @@index([action])
  @@index([createdAt])
}
